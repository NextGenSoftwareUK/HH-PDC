# ── OASIS API ────────────────────────────────────────────────────────────────
# Production OASIS Web4 API (default, no trailing slash)
VITE_OASIS_API_URL=https://api.oasisweb4.com

# Local OASIS ONODE server (use for dev when running ONODE locally on port 5003)
# VITE_OASIS_API_URL=http://localhost:5003

# ── Admin credentials for seeding (NEVER commit real credentials) ─────────────
# Used only by the one-time seedAllMapHolons() call.
# In production use a dedicated service avatar, not a personal account.
VITE_OASIS_SEED_USERNAME=your_avatar_username
VITE_OASIS_SEED_PASSWORD=your_avatar_password

# ── Optional: pre-seeded Pulmón Verde OAPP holon ID ──────────────────────────
# Once you've run the seeder, paste the returned pv holon ID here so the
# app can load it directly without a metadata query on startup.
VITE_PV_HOLON_ID=
